{
  "compilerOptions": {
    "target": "es2020",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
