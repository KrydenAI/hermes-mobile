{
  "expo": {
    "name": "Hermes Mobile",
    "slug": "hermes-mobile",
    "scheme": "hermesmobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.kryden.hermesmobile"
    },
    "android": {
      "package": "ai.kryden.hermesmobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
